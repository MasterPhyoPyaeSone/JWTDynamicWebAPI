<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RBAC Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@{
    bool hasSidebar = (bool?)ViewData["HasSidebar"] ?? false;
}

@if (hasSidebar)
{
    <!-- ── Sidebar Layout ────────────────────── -->
    <div class="app-layout">
        <aside class="sidebar" id="sidebar">
            <!-- Logo -->
            <div class="sidebar-logo">
                <div class="logo-icon">🔐</div>
                <div>
                    <div class="logo-text">RBACPanel</div>
                    <div class="logo-sub">JWT Protected</div>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="sidebar-nav">
                <div class="nav-section-title">Menu</div>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
                   href="/Dashboard" data-admin-only style="display:none">
                    <span class="nav-icon">🏠</span>
                    Dashboard
                </a>

                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Products" ? "active" : "")"
                   href="/Products">
                    <span class="nav-icon">📦</span>
                    Products
                </a>

                <div class="nav-section-title" style="margin-top:8px;">Account</div>

                <a class="nav-item" href="/" onclick="logout(); return false;">
                    <span class="nav-icon">🚪</span>
                    Logout
                </a>
            </nav>

            <!-- User Info -->
            <div class="sidebar-user">
                <div class="user-avatar" id="sidebar-avatar">U</div>
                <div class="user-info">
                    <div class="user-name" id="sidebar-username">Loading…</div>
                    <span class="badge badge-blue" id="sidebar-role"></span>
                </div>
                <button class="btn-logout" onclick="logout()" title="Logout">↩</button>
            </div>
        </aside>

        <!-- Main -->
        <div class="main-content">
            <header class="topbar">
                <div class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</div>
            </header>
            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    <!-- ── Fullpage Layout (Home / Login) ──── -->
    @RenderBody()
}

<!-- Scripts -->
<script src="~/js/app.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

@if (hasSidebar)
{
    <script>
        // Init sidebar with user data from JWT
        document.addEventListener('DOMContentLoaded', initSidebarUser);
    </script>
}
</body>
</html>
